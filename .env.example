# ============================================================================
# FIRESONG HERALD — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file to version control — it contains secrets.

# ============================================================================
# DATABASE
# ============================================================================
# PostgreSQL credentials and connection details
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=firesong_db
POSTGRES_PORT=5432

# Full connection string used by Prisma ORM and bot services
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Note: When running in Docker, use 'db' as the host. Locally, use 'localhost'.
DATABASE_URL=postgresql://postgres:your_secure_password_here@db:5432/firesong_db

# ============================================================================
# DISCORD
# ============================================================================
# Discord bot token (from Discord Developer Portal > Applications > Bot)
# Get it from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Discord application client ID
# Get it from: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_client_id_here

# Discord guild/server ID for development/testing
# Right-click your server in Discord, copy "Server ID" if Dev Mode is enabled
DISCORD_GUILD_ID=your_guild_id_here

# URL to invite the bot to servers (with appropriate permissions and scopes)
BOT_INVITE_URL=your_bot_invite_url_here

# Discord application client secret (OAuth2)
DISCORD_CLIENT_SECRET=your_client_secret_here

# Discord OAuth2 redirect URI
DISCORD_REDIRECT_URI=http://localhost:3001/auth/discord/callback

# JWT secret key for signing authentication tokens
JWT_SECRET=your_jwt_secret_here

# ============================================================================
# API & DASHBOARD
# ============================================================================
# Port for the Fastify API server
API_PORT=3001

# Base URL for the API (used for client-side requests and CORS)
API_URL=http://api:3001

# Host address for the API server to bind to
API_HOST=0.0.0.0

# URL of the SvelteKit dashboard (used for CORS and client-side redirects)
DASHBOARD_URL=http://localhost:5173
